{
  "eslint.packageManager": "pnpm",
  "eslint.useFlatConfig": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "eslint.workingDirectories": [
    {
      "directory": "./apps/backend",
      "changeProcessCWD": true
    },
    {
      "directory": "./apps/frontend",
      "changeProcessCWD": true
    }
  ],
  "cSpell.words": [
    "Anvara",
    "cuid",
    "Hackathon",
    "healthcheck",
    "initdb",
    "isready",
    "takehome",
    "yourname"
  ]
}
