# Database (port 5498 to avoid conflicts)
DATABASE_URL=postgresql://postgres:postgres@localhost:5498/anvara_sponsorships

# Backend (port 4291)
BACKEND_PORT=4291
REDIS_URL=redis://localhost:6379
# Optional local overrides for rate limiting.
BACKEND_GLOBAL_RATE_LIMIT=1000
BACKEND_AUTH_RATE_LIMIT=50

# Frontend (port 3847)
NEXT_PUBLIC_API_URL=http://localhost:4291
# Optional: Google Analytics 4 measurement ID. Omit for local dev.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXX
FRONTEND_AUTH_GET_RATE_LIMIT=300
FRONTEND_AUTH_CREDENTIAL_RATE_LIMIT=50
FRONTEND_AUTH_RECOVERY_RATE_LIMIT=30
FRONTEND_AUTH_SIGN_OUT_RATE_LIMIT=90
FRONTEND_AUTH_MUTATION_RATE_LIMIT=180

# Better Auth
BETTER_AUTH_SECRET=use-openssl-rand-hex-32-to-generate-this
BETTER_AUTH_URL=http://localhost:3847
